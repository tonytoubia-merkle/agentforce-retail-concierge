# Agentforce Configuration
# Agent ID and instance URL are needed client-side for API routing
VITE_AGENTFORCE_AGENT_ID=your-agent-id
VITE_AGENTFORCE_INSTANCE_URL=https://your-instance.my.salesforce.com

# Skin Concierge Agent — separate Agentforce agent with skin-analyzer + where-to-buy topics only
# Signup + agent setup: https://yce.makeupar.com/  (14-day free trial)
VITE_SKIN_ADVISOR_AGENT_ID=your-skin-concierge-agent-id

# Perfect Corp YouCam AI Skin Analysis
# Get API key + secret at: https://yce.makeupar.com/api-console/en/api-keys/
# Leave both blank to use mock skin analysis (for local dev without a trial key)
VITE_PERFECT_CORP_API_KEY=
VITE_PERFECT_CORP_SECRET_KEY=

# OAuth credentials — server-side only (NOT bundled into the browser)
# Used by server/index.js for the /api/sf/token endpoint
VITE_AGENTFORCE_CLIENT_ID=your-connected-app-consumer-key
VITE_AGENTFORCE_CLIENT_SECRET=your-connected-app-consumer-secret

# Image Generation Provider: imagen | firefly | cms-only | none
VITE_IMAGE_PROVIDER=none
VITE_IMAGEN_API_KEY=your-google-ai-api-key
VITE_FIREFLY_CLIENT_ID=your-firefly-client-id
VITE_FIREFLY_CLIENT_SECRET=your-firefly-client-secret
VITE_CMS_CHANNEL_ID=
VITE_CMS_SPACE_ID=

# Commerce Cloud Configuration (Headless Storefront)
VITE_COMMERCE_BASE_URL=https://your-instance.commercecloud.salesforce.com
VITE_COMMERCE_CLIENT_ID=your-client-id
VITE_COMMERCE_SITE_ID=your-site-id
VITE_COMMERCE_ACCESS_TOKEN=your-access-token

# Data Cloud Configuration (reads + writes customer profiles, chat summaries, events)
VITE_DATACLOUD_BASE_URL=https://your-instance.salesforce.com
VITE_DATACLOUD_ACCESS_TOKEN=your-access-token

# SF Personalization (Data Cloud Web SDK)
# MC Advanced journeys are Flows on Core — no separate MC API credentials needed.
# Personalization events flow into Data Cloud; Triggered Actions handle abandonment,
# and Record-Triggered Flows handle lifecycle journeys (welcome, post-purchase, etc.).
VITE_SFP_BEACON_URL="https://cdn.c360a.salesforce.com/beacon/c360a/your-dataset-id/scripts/c360a.min.js"
VITE_SFP_DATASET=your-dataset-id

# Feature Flags
VITE_USE_MOCK_DATA=true
VITE_ENABLE_GENERATIVE_BACKGROUNDS=false
VITE_ENABLE_PRODUCT_TRANSPARENCY=true
